// firestore.rules - Firestore Security Rules
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ──────────────────────────────────────────
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isValidJob() {
      let data = request.resource.data;
      return data.keys().hasAll(['title', 'slug', 'category', 'isActive']) &&
             data.title is string &&
             data.title.size() > 0 &&
             data.slug is string &&
             data.slug.size() > 0;
    }

    // ── Jobs collection ───────────────────────────────────────────
    match /jobs/{jobId} {
      // Anyone can read active jobs (for SSG + ISR)
      allow read: if true;
      // Only admin can write
      allow create: if isAdmin() && isValidJob();
      allow update: if isAdmin() && isValidJob();
      allow delete: if isAdmin();
    }

    // ── Results collection ────────────────────────────────────────
    match /results/{resultId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── Admit Cards collection ────────────────────────────────────
    match /admitCards/{admitCardId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── Blogs collection ──────────────────────────────────────────
    match /blogs/{blogId} {
      // Only published blogs are readable by public
      allow read: if resource.data.isPublished == true || isAdmin();
      allow write: if isAdmin();
    }

    // ── Notifications ─────────────────────────────────────────────
    match /notifications/{notifId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── Alerts (breaking news ticker) ─────────────────────────────
    match /alerts/{alertId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── Settings ──────────────────────────────────────────────────
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── Admin users list ──────────────────────────────────────────
    match /admins/{userId} {
      // Only existing admins can read/modify admin list
      allow read: if isAdmin() || request.auth.uid == userId;
      allow write: if isAdmin();
    }

    // ── FCM Tokens (user push notification tokens) ────────────────
    match /fcmTokens/{tokenId} {
      // Users can register their own token
      allow create: if isAuthenticated() || true; // Allow anonymous for push subscriptions
      allow read, update, delete: if isAdmin();
    }

    // ── All other documents: deny by default ──────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
